{
  "schema_version": "ocean-database-adapter-config-v1",
  "adapter": "pubmed",
  "slug": "pubmed",
  "label": "PubMed",
  "family": "literature_metadata",
  "default_arguments": {
    "query": "TP53",
    "retmax": 2,
    "timeout": 20
