{
  "schema_version": "ocean-database-tool-api-v1",
  "adapter": "gnomad",
  "tool_name": "gnomAD",
  "tool_slug": "gnomad",
  "tool_family": "population_genetics",
  "interface_type": "reef_api_database_packet",
  "python_wrapper": "scripts/query_packet.py",
  "example_input": "examples/query.example.json",
  "default_output": "outputs/gnomad-reef-packet.json",
  "commands": [
    {
      "name": "query-packet",
      "description": "Create a bounded dry-run Reef API/database packet.",
      "argv": [
        "python3",
        "scripts/query_packet.py",
        "--variant-id",
        "11-5227002-T-A",
        "--gnomad-dataset",
        "gnomad_r4",
        "--retmax",
        "2",
        "--out",
        "outputs/gnomad-reef-packet.json"
      ]
    },
    {
      "name": "query-packet-live",
      "description": "Create a bounded live Reef API/database packet with explicit network execution.",
      "argv": [
        "python3",
        "scripts/query_packet.py",
        "--variant-id",
        "11-5227002-T-A",
        "--gnomad-dataset",
        "gnomad_r4",
        "--retmax",
        "2",
        "--execute",
        "--out",
        "outputs/gnomad-reef-packet.json"
      ]
    }
  ],
  "output_contract": {
    "ocean_module": "Reef",
    "boundary_required": true,
    "handoff": "Reef -> Iceberg/Anchor"
  },
  "evidence_boundary": {
    "can_support": "population-frequency or constraint-resource provenance",
    "cannot_support_alone": "pathogenicity, diagnosis, treatment actionability, or mechanism",
    "terms_url": "https://gnomad.broadinstitute.org/help/terms"
  }
}
