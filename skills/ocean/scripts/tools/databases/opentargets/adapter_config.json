{
  "schema_version": "ocean-database-adapter-config-v1",
  "adapter": "opentargets",
  "slug": "opentargets",
  "label": "Open Targets",
  "family": "drug_target",
  "default_arguments": {
    "ensembl_id": "ENSG00000141510",
