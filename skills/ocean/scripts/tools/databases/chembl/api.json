{
  "schema_version": "ocean-database-tool-api-v1",
  "adapter": "chembl",
  "tool_name": "ChEMBL",
  "tool_slug": "chembl",
  "tool_family": "drug_target",
  "interface_type": "reef_api_database_packet",
  "python_wrapper": "scripts/query_packet.py",
  "example_input": "examples/query.example.json",
  "default_output": "outputs/chembl-reef-packet.json",
  "commands": [
    {
      "name": "query-packet",
      "description": "Create a bounded dry-run Reef API/database packet.",
      "argv": [
        "python3",
        "scripts/query_packet.py",
        "--query",
        "aspirin",
        "--retmax",
        "2",
        "--out",
        "outputs/chembl-reef-packet.json"
      ]
    },
    {
      "name": "query-packet-live",
      "description": "Create a bounded live Reef API/database packet with explicit network execution.",
      "argv": [
        "python3",
        "scripts/query_packet.py",
        "--query",
        "aspirin",
        "--retmax",
        "2",
        "--execute",
        "--out",
        "outputs/chembl-reef-packet.json"
      ]
    }
  ],
  "output_contract": {
    "ocean_module": "Reef",
    "boundary_required": true,
    "handoff": "Reef -> Iceberg/Compass"
  },
  "evidence_boundary": {
    "can_support": "compound/target/assay metadata and ChEMBL identifier provenance",
    "cannot_support_alone": "therapeutic efficacy, safety, mechanism, or clinical readiness",
    "terms_url": "https://chembl.gitbook.io/chembl-interface-documentation/about"
  }
}
