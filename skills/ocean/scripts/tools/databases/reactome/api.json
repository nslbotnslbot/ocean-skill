{
  "schema_version": "ocean-database-tool-api-v1",
  "adapter": "reactome",
  "tool_name": "Reactome",
  "tool_slug": "reactome",
  "tool_family": "pathway",
  "interface_type": "reef_api_database_packet",
  "python_wrapper": "scripts/query_packet.py",
  "example_input": "examples/query.example.json",
  "default_output": "outputs/reactome-reef-packet.json",
  "commands": [
    {
      "name": "query-packet",
      "description": "Create a bounded dry-run Reef API/database packet.",
      "argv": [
        "python3",
        "scripts/query_packet.py",
        "--query",
        "TP53",
        "--species-name",
        "Homo sapiens",
        "--retmax",
        "2",
        "--out",
        "outputs/reactome-reef-packet.json"
      ]
    },
    {
      "name": "query-packet-live",
      "description": "Create a bounded live Reef API/database packet with explicit network execution.",
      "argv": [
        "python3",
        "scripts/query_packet.py",
        "--query",
        "TP53",
        "--species-name",
        "Homo sapiens",
        "--retmax",
        "2",
        "--execute",
        "--out",
        "outputs/reactome-reef-packet.json"
      ]
    }
  ],
  "output_contract": {
    "ocean_module": "Reef",
    "boundary_required": true,
    "handoff": "Reef -> Iceberg/Compass"
  },
  "evidence_boundary": {
    "can_support": "pathway/resource discovery and pathway-context provenance",
    "cannot_support_alone": "pathway activity, causal disease mechanism, or treatment effect",
    "terms_url": "https://reactome.org/license"
  }
}
