{
  "schema_version": "ocean-database-tool-api-v1",
  "adapter": "clinvar",
  "tool_name": "ClinVar",
  "tool_slug": "clinvar",
  "tool_family": "variant_clinical_annotation",
  "interface_type": "reef_api_database_packet",
  "python_wrapper": "scripts/query_packet.py",
  "example_input": "examples/query.example.json",
  "default_output": "outputs/clinvar-reef-packet.json",
  "commands": [
    {
      "name": "query-packet",
      "description": "Create a bounded dry-run Reef API/database packet.",
      "argv": [
        "python3",
        "scripts/query_packet.py",
        "--query",
        "BRCA1",
        "--retmax",
        "2",
        "--out",
        "outputs/clinvar-reef-packet.json"
      ]
    },
    {
      "name": "query-packet-live",
      "description": "Create a bounded live Reef API/database packet with explicit network execution.",
      "argv": [
        "python3",
        "scripts/query_packet.py",
        "--query",
        "BRCA1",
        "--retmax",
        "2",
        "--execute",
        "--out",
        "outputs/clinvar-reef-packet.json"
      ]
    }
  ],
  "output_contract": {
    "ocean_module": "Reef",
    "boundary_required": true,
    "handoff": "Reef -> Iceberg/Anchor"
  },
  "evidence_boundary": {
    "can_support": "ClinVar record discovery and clinical-assertion metadata provenance",
    "cannot_support_alone": "diagnosis, treatment guidance, or pathogenicity without inspected details",
    "terms_url": "https://www.ncbi.nlm.nih.gov/clinvar/"
  }
}
