{
  "schema_version": "ocean-database-tool-api-v1",
  "adapter": "quickgo",
  "tool_name": "QuickGO",
  "tool_slug": "quickgo",
  "tool_family": "ontology",
  "interface_type": "reef_api_database_packet",
  "python_wrapper": "scripts/query_packet.py",
  "example_input": "examples/query.example.json",
  "default_output": "outputs/quickgo-reef-packet.json",
  "commands": [
    {
      "name": "query-packet",
      "description": "Create a bounded dry-run Reef API/database packet.",
      "argv": [
        "python3",
        "scripts/query_packet.py",
        "--query",
        "apoptosis",
        "--retmax",
        "2",
        "--out",
        "outputs/quickgo-reef-packet.json"
      ]
    },
    {
      "name": "query-packet-live",
      "description": "Create a bounded live Reef API/database packet with explicit network execution.",
      "argv": [
        "python3",
        "scripts/query_packet.py",
        "--query",
        "apoptosis",
        "--retmax",
        "2",
        "--execute",
        "--out",
        "outputs/quickgo-reef-packet.json"
      ]
    }
  ],
  "output_contract": {
    "ocean_module": "Reef",
    "boundary_required": true,
    "handoff": "Reef -> Iceberg/Harbor"
  },
  "evidence_boundary": {
    "can_support": "GO term metadata and annotation-resource provenance",
    "cannot_support_alone": "direct molecular mechanism, causality, or phenotype proof",
    "terms_url": "https://www.ebi.ac.uk/QuickGO/api/index.html"
  }
}
