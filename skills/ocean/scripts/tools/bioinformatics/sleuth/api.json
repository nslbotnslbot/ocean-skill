{
  "schema_version": "ocean-tool-api-v1",
  "tool_name": "sleuth",
  "tool_slug": "sleuth",
  "tool_family": "differential_expression",
  "maturity": "L0/L1 scaffold",
  "interface_type": "provenance_to_source_packet",
  "python_wrapper": "scripts/create_source_packet.py",
  "example_input": "examples/run-record.example.json",
  "default_output": "outputs/sleuth-source-packet.json",
  "commands": [
    {
      "name": "create-source-packet",
      "description": "Convert an inspected tool run record into a bounded OCEAN software source packet.",
      "argv": [
        "python3",
        "scripts/create_source_packet.py",
        "--input",
        "examples/run-record.example.json",
        "--output",
        "outputs/sleuth-source-packet.json"
      ]
    },
    {
      "name": "probe-or-plan",
      "description": "Run a bounded availability probe or create a launcher/source-packet plan for this tool.",
      "argv": [
        "python3",
        "scripts/probe_or_plan.py",
        "--output",
        "outputs/sleuth-probe-or-plan.json"
      ]
    },
    {
      "name": "package-probe",
      "description": "Run the bounded per-tool Python/R package availability/version probe.",
      "argv": [
        "python3",
        "scripts/run_package.py",
        "probe",
        "--output",
        "outputs/sleuth-package-probe.json",
        "--packet-output",
        "outputs/sleuth-package-probe-source-packet.json"
      ]
    },
    {
      "name": "package-run-record",
      "description": "Run an explicit user-supplied Python/R script and record bounded provenance.",
      "argv": [
        "python3",
        "scripts/run_package.py",
        "run-script",
        "--script",
        "/path/to/inspected_script.R",
        "--args-json",
        "[\"<user-supplied arguments>\"]",
        "--output",
        "outputs/sleuth-package-run-record.json",
        "--packet-output",
        "outputs/sleuth-package-run-source-packet.json"
      ]
    }
  ],
  "required_input_fields": [
    "tool_name",
    "tool_slug",
    "tool_version",
    "task_intent",
    "command_line",
    "parameters",
    "reference_or_index",
    "input_files",
    "output_files",
    "logs_or_qc",
    "environment",
    "date"
  ],
  "output_contract": {
    "source_type": "bioinformatics_software_run",
    "boundary_status": "queried_evidence",
    "handoff": "Anchor"
  },
  "evidence_boundary": {
    "does_not_run_external_tool": true,
    "cannot_support_alone": [
      "biological mechanism",
      "causal conclusion",
      "clinical utility",
      "publication readiness",
      "reproducibility without rerun/log/environment checks"
    ]
  },
  "usage_reference": "references/tool_usage.md",
  "execution_contract": {
    "availability_smoke_required_before_execution_claim": true,
    "real_run_record_required_before_evidence_packet": true,
    "install_or_container_plan_required_if_unavailable": true,
    "license_or_terms_check_required_when_applicable": true
  },
  "probe_or_plan_wrapper": "scripts/probe_or_plan.py",
  "wrapper_config": "wrapper_config.json",
  "package_runner_wrapper": "scripts/run_package.py"
}
